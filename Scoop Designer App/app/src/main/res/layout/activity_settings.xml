<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    tools:context=".SettingsActivity">

    <!-- LIVE PREVIEW AREA -->
    <FrameLayout
        android:id="@+id/preview_area"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Container (Bottom Layer) -->
        <ImageView
            android:id="@+id/preview_cone"
            android:layout_width="160dp"
            android:layout_height="182dp"
            android:layout_gravity="center|bottom"
            android:src="@drawable/cone"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/preview_cup"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center|bottom"
            android:src="@drawable/cup"
            android:visibility="gone" />

        <!-- Scoop (Top Layer) -->
        <ImageView
            android:id="@+id/preview_scoop"
            android:layout_width="163dp"
            android:layout_height="234dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:src="@drawable/vanilla" />
    </FrameLayout>

    <!--  SELECTION AREA -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Step 2: Pick your Flavor"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/preview_area" />

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView">

        <RadioButton
            android:id="@+id/radio_vanilla"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Vanilla"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radio_mint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mint"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radio_strawberry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Strawberry"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radio_mango"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mango"
            android:textSize="18sp" />

        <RadioButton
            android:id="@+id/radio_chocolate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chocolate"
            android:textSize="18sp" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Next Step"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>