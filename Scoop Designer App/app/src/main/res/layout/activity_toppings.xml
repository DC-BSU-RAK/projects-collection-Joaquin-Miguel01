<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    tools:context=".ToppingsActivity">

    <FrameLayout
        android:id="@+id/preview_area"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/preview_cone"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center|bottom"
            android:src="@drawable/cone" />

        <ImageView
            android:id="@+id/preview_cup"
            android:layout_width="200dp"
            android:layout_height="160dp"
            android:layout_gravity="center|bottom"
            android:src="@drawable/cup"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/preview_scoop"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="110dp"
            android:src="@drawable/vanilla" />

        <ImageView
            android:id="@+id/preview_sprinkles"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="110dp"
            android:src="@drawable/sprinkles"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/preview_cherry"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="220dp"
            android:src="@drawable/cherry"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_step3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 3: Add Toppings"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/preview_area"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_step3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <CheckBox
            android:id="@+id/check_cherry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add a Cherry"
            android:textSize="20sp"
            android:padding="10dp" />

        <CheckBox
            android:id="@+id/check_sprinkles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Colorful Sprinkles"
            android:textSize="20sp"
            android:padding="10dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_finish"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="Finish My Ice Cream!"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="50dp" />

</androidx.constraintlayout.widget.ConstraintLayout>